# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── YouTube Data API v3 (optional but recommended) ────────────────────────────
# Provides better search results and avoids scraper rate limits.
# Get a free key at https://console.cloud.google.com
#   → Enable "YouTube Data API v3" → Credentials → Create API Key
YOUTUBE_API_KEY=

# ── Session config ────────────────────────────────────────────────────────────
SESSION_SECRET=change_this_to_a_long_random_string
SESSION_EXPIRY_HOURS=8

# ── HTTPS certs (optional overrides) ─────────────────────────────────────────
# Certs are auto-generated on first boot into the certs/ directory.
# Only set these if you want to use your own cert files.
# CERT_PATH=../certs/server.pem
# KEY_PATH=../certs/server-key.pem
# CA_CERT_PATH=../certs/rootCA.pem
